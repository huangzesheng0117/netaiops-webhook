app_name: netaiops-webhook
listen_host: 0.0.0.0
listen_port: 18080

defaults:
  vendor: ""
  severity: ""

llm:
  enabled: false
  provider: openai_compatible
  base_url: "http://10.10.10.10:8000/v1"
  api_key: "YOUR_API_KEY"
  model: "qwen3-max"
  timeout: 60
  verify_ssl: false
  temperature: 0.2
  max_tokens: 1200

analysis:
  save_prompt: false
  save_result: true
